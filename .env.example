# OCM repository and component overrides for the local demo setup.
# Copy this file to .env and adjust the values.
# Uses plain KEY=value syntax (no "export") for Taskfile dotenv compatibility.
OPENMCP_OCM_REPOSITORY=ghcr.io/openmcp-project/components
OPENMCP_OCM_COMPONENT_NAME=github.com/openmcp-project/openmcp
